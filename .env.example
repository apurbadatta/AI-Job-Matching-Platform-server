# Server Environment Variables
# Copy this file to .env and fill in the values

# Server
PORT=5000
CLIENT_URL=http://localhost:3000

# MongoDB
MONGO_URI=

# Better Auth Secret (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET=

# AI
GEMINI_API_KEY=

# Payments
STRIPE_SECRET_KEY=

# OAuth (Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
