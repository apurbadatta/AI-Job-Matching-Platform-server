# Server
PORT=5000
NODE_ENV=production

# Client URL (your Vercel deployment URL)
CLIENT_URL=https://your-app.vercel.app

# Better Auth
BETTER_AUTH_URL=https://your-server.onrender.com
BETTER_AUTH_SECRET=your-secret-here

# MongoDB
MONGO_URI=mongodb+srv://user:pass@cluster.mongodb.net/dbname

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI (optional - app works without it)
GEMINI_API_KEY=your-gemini-api-key

# Stripe
STRIPE_SECRET_KEY=sk_test_your-stripe-secret
STRIPE_PRO_PRICE_ID=price_your-pro-price
STRIPE_BUSINESS_PRICE_ID=price_your-business-price
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
